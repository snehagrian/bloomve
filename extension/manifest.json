{
  "manifest_version": 3,
  "name": "bloomve",
  "version": "1.0.15",
  "description": "Share and save jobs with friends.",
  "icons": {
    "16": "icons/icon-16.png",
    "24": "icons/icon-24.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": [
    "*://*.linkedin.com/jobs/*",
    "*://*.linkedin.com/company/*/people/*",
    "*://*.indeed.com/*",
    "*://*.myworkdayjobs.com/*",
    "*://*.greenhouse.io/*",
    "http://localhost/*",
    "*://localhost/*",
    "*://127.0.0.1/*",
    "https://*.bloomve.app/*",
    "https://*.bloomvey.app/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/jobs/*",
        "*://*.indeed.com/*",
        "*://*.myworkdayjobs.com/*",
        "*://*.greenhouse.io/jobs/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://localhost/*", "*://127.0.0.1/*", "https://*.bloomve.app/*", "https://*.bloomvey.app/*"],
      "js": ["authBridge.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/bloomve-icon.svg", "icons/bloomve-hand-icon.svg"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_title": "bloomve",
    "default_icon": {
      "16": "icons/icon-16.png",
      "24": "icons/icon-24.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
