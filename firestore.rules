rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /rooms/{roomId} {
      allow read: if resource.data.privacy == "public" || (signedIn() && resource.data.ownerId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.ownerId == request.auth.uid;

      match /posts/{postId} {
        allow read: if get(/databases/$(database)/documents/rooms/$(roomId)).data.privacy == "public"
                    || (signedIn() && get(/databases/$(database)/documents/rooms/$(roomId)).data.ownerId == request.auth.uid);

        allow create: if signedIn()
                      && request.resource.data.userId == request.auth.uid
                      && (
                        get(/databases/$(database)/documents/rooms/$(roomId)).data.type == "chat"
                        || get(/databases/$(database)/documents/rooms/$(roomId)).data.ownerId == request.auth.uid
                      );

        allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
      }
    }
  }
}
